/* LabFlow 分割器样式 */

/* 分割器容器 */
QSplitter {
    background-color: transparent;
}

/* 分割器手柄 */
QSplitter::handle {
    background-color: transparent;
    min-width: 8px;
    min-height: 8px;
}

/* 分割器手柄悬停状态 */
QSplitter::handle:hover {
    background-color: rgba(255, 122, 0, 0.1);
}

/* 分割器手柄拖拽状态 */
QSplitter::handle:pressed {
    background-color: rgba(255, 122, 0, 0.2);
}
